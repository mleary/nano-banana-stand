{
  
  "permissions": {
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "defaultMode": "acceptEdits",  
    "allow": [
      "Bash(air:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(git checkout:*)",
      "Bash(git grep:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(R:*)",
      "Bash(rm:*)",
      "Skill(*)",
      "WebFetch(domain:cran.r-project.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:ai.google.dev)",
      "WebFetch(domain:ai.google.dev)",
      "WebFetch(domain:posit-dev.github.io)"
    ],
    "deny": [
      "Read(.Renviron)", 
      "Read(.env)",
      "Bash(gh pr review --approve:*)",
      "Bash(gh pr merge:*)",
      "Bash(git push:*)"
    ]
  }
}

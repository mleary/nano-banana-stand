# Copy to .env and fill in your values.
# Never commit a .env file with real keys.

# --- Provider selection ---
# Options: google-gemini | openai | fal | replicate
IMAGE_PROVIDER=google-gemini

# --- Google Gemini (default provider) ---
# Used for Imagen 3 image generation and chatlas prompt enhancement
GOOGLE_API_KEY=your-google-api-key-here

# --- OpenAI (DALL-E 3) ---
OPENAI_API_KEY=your-openai-api-key-here

# --- fal.ai (Flux) ---
FAL_KEY=your-fal-key-here

# --- Replicate (Flux) ---
REPLICATE_API_TOKEN=your-replicate-token-here

# --- Storage (Railway volumes) ---
DB_PATH=/data/db.sqlite3
STORAGE_DIR=/data/images

# Copy to .env and fill in your values.
# Never commit a .env file with real keys.

# --- Google Gemini (default provider) ---
GOOGLE_API_KEY=your-google-api-key-here

# --- OpenAI (optional / future) ---
OPENAI_API_KEY=your-openai-api-key-here

# --- Google OAuth (leave blank to disable authentication) ---
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Public URL of your deployed app — used as the OAuth redirect URI.
# For local dev use http://localhost:8501
APP_URL=https://your-app.railway.app

# (Optional) Restrict sign-in to one Google Workspace domain, e.g. mycompany.com
GOOGLE_ALLOWED_DOMAIN=mycompany.com

# (Optional) Comma-separated list of allowed email addresses, e.g. alice@gmail.com,bob@example.com
GOOGLE_ALLOWED_EMAILS=alice@gmail.com,bob@example.com

# --- Storage paths (defaults write to local data/ dir; override for Railway volumes) ---
# DB_PATH=/data/db.sqlite3
# STORAGE_DIR=/data/images
# REFERENCES_DIR=/data/references
# PRESETS_PATH=/data/presets.yaml
